---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import AnimatedText from "../../components/AnimatedText.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="About - Mr. Guo" description="Product manager, developer, digital marketing consultant, and PMF advisor." lang="en">
  <Navbar lang="en" />

  <section class="relative z-20 container mx-auto my-12 px-7 lg:px-0">
    <div class="relative z-20 w-full mx-auto mt-16 mb-16 text-center">
      <h2 class="text-4xl font-brand text-center tracking-normal text-primary sm:text-4xl lg:text-5xl">
        <AnimatedText text="About Me" as="div" duration="0.6" delay="0.2" stagger="0.08" />
      </h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-10">
      <!-- Bio -->
      <div class="bg-white/85 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm p-8 md:p-10" data-aos="fade-up" data-aos-duration="500">
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-shrink-0">
            <img src="/assets/tools/logo/mrguo.png" alt="Mr. Guo" class="w-28 h-28 rounded-2xl border-4 border-white dark:border-neutral-800/60 shadow-md" />
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-brand text-neutral-900 dark:text-white mb-3">Mr'Guo</h3>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
              I'm a product manager, developer, and digital marketing consultant with a passion for building products that
              bridge the gap between technology and business. Over the years, I've played multiple roles — from hands-on
              development and product strategy to growth marketing and business consulting.
            </p>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
              My work spans AI SaaS, 3D tools, e-commerce, and digital marketing, where I help teams find product-market fit,
              scale their operations, and build sustainable growth engines.
            </p>
          </div>
        </div>
      </div>

      <!-- Skills / Roles -->
      <h3 class="text-2xl font-brand text-primary text-center" data-aos="fade-up" data-aos-duration="500">
        <AnimatedText text="Roles I Play" as="div" duration="0.6" delay="0.2" stagger="0.06" />
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white/85 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-aos="fade-up" data-aos-duration="500" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary dark:text-primary-light"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
          </div>
          <h4 class="text-lg font-semibold text-neutral-900 dark:text-white mb-2">Product Manager</h4>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">End-to-end product strategy, roadmap planning, and cross-functional team leadership for SaaS products.</p>
        </div>

        <div class="bg-white/85 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-aos="fade-up" data-aos-duration="500" data-aos-delay="100">
          <div class="w-12 h-12 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary dark:text-primary-light"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
          </div>
          <h4 class="text-lg font-semibold text-neutral-900 dark:text-white mb-2">Developer</h4>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">Full-stack development with modern web technologies, AI integration, and automation tooling.</p>
        </div>

        <div class="bg-white/85 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-aos="fade-up" data-aos-duration="500" data-aos-delay="200">
          <div class="w-12 h-12 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary dark:text-primary-light"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"></path><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"></path><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"></path><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"></path><circle cx="12" cy="12" r="2"></circle></svg>
          </div>
          <h4 class="text-lg font-semibold text-neutral-900 dark:text-white mb-2">Digital Marketing Consultant</h4>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">Growth strategy, SEO, SEM, and performance marketing for B2B and B2C SaaS companies.</p>
        </div>

        <div class="bg-white/85 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" data-aos="fade-up" data-aos-duration="500" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary dark:text-primary-light"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
          </div>
          <h4 class="text-lg font-semibold text-neutral-900 dark:text-white mb-2">PMF & Strategy Advisor</h4>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">Product-market fit validation, business model design, and go-to-market strategy for early-stage startups.</p>
        </div>
      </div>

      <!-- Contact CTA -->
      <div class="text-center pt-4 pb-8" data-aos="fade-up" data-aos-duration="500">
        <p class="text-neutral-600 dark:text-neutral-400 mb-6">Interested in working together? Let's connect.</p>
        <div class="flex justify-center gap-4">
          <a href="mailto:xjzzxwork@gmail.com" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-btn-primary dark:bg-btn-primary-dark text-white text-sm font-medium shadow-[0px_2px_3px_0_rgba(0,0,0,0.1)] transition-all duration-300 hover:bg-btn-primary-hover dark:hover:bg-btn-primary-dark-hover hover:-translate-y-0.5 hover:shadow-[0px_6px_9px_0_rgba(61,99,171,0.15)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            Email Me
          </a>
          <a href="https://x.com/gzzhangguo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 text-sm font-medium transition-all duration-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
            Follow on X
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="en" />

  <script>
    import AOS from "aos";
    import "aos/dist/aos.css";
    AOS.init({ duration: 600, easing: "ease-out", once: true });
  </script>
</Layout>
