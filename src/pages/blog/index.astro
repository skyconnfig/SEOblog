---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import AnimatedText from "../../components/AnimatedText.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = allPosts[0];
const posts = allPosts.slice(1, 7);
const totalPages = Math.ceil(allPosts.length / 6);
const currentPage = 1;
---

<Layout title="Blog - LXSBest" description="Explore my thoughts on design and development, the convergence of thinking and innovation." lang="en">
  <Navbar lang="en" />

  <section class="relative z-20 container mx-auto my-12 px-7 lg:px-0">
    <div class="relative z-20 w-full mx-auto mt-16 mb-16 text-center">
      <h2 class="text-4xl font-brand text-center tracking-normal text-primary sm:text-4xl lg:text-5xl">
        <AnimatedText text="My Blog" as="div" duration="0.6" delay="0.2" stagger="0.08" />
      </h2>
      <div class="mt-3 text-sm leading-6 sm:mt-4 lg:mt-6 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg text-neutral-700 dark:text-neutral-300 max-w-full lg:max-w-2xl m-auto">
        <AnimatedText text="Explore my thoughts on design and development, the convergence of thinking and innovation. Feel free to follow the updates!" as="div" duration="1" delay="0.6" stagger="0.03" />
      </div>
    </div>

    <!-- Featured Post -->
    {featured && (
    <section class="mb-16">
      <div class="site-container">
        <h2 class="text-3xl font-brand mb-6 text-primary">
          <AnimatedText text="Featured" as="div" duration="0.6" delay="0.75" stagger="0.08" />
        </h2>
        <div class="p-1 rounded-2xl">
          <article class="group relative overflow-hidden bg-bg-secondary border-primary/35 p-4 dark:bg-neutral-900 rounded-2xl backdrop-blur-sm transition-all duration-500 md:flex md:items-center" data-aos="fade-up-sm" data-aos-delay="1000">
            <!-- Image -->
            <div class="relative overflow-hidden rounded-2xl border-4 border-white dark:border-neutral-800/60 md:w-1/2">
              <img src={featured.data.image || "/assets/blog/ai-cover.webp"} alt={featured.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 aspect-[3/2]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
                <span class="w-14 h-14 bg-white/95 dark:bg-neutral-800/95 backdrop-blur-sm rounded-full flex items-center justify-center transform translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 shadow-lg hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
                </span>
              </div>
              <a class="absolute inset-0 z-10" href={`/blog/${featured.slug}`}><span class="sr-only">Read More About {featured.data.title}</span></a>
            </div>
            <!-- Content -->
            <div class="p-6 px-2 md:p-6 flex flex-col md:w-1/2">
              <div class="flex items-center text-sm mb-4 gap-2">
                <time class="inline-flex items-center text-neutral-500 dark:text-neutral-400 text-xs">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5 opacity-60"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                  {featured.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
                </time>
                {featured.data.tags && featured.data.tags.length > 0 && (
                  <>
                    <span class="text-neutral-400 dark:text-neutral-500">·</span>
                    <span class="inline-flex items-center rounded-full bg-bg-secondary/8 dark:bg-bg-secondary/15 px-3 py-1 text-[11px] font-light text-primary/75 dark:text-primary-light/85 border border-primary/25 dark:border-primary/25">{featured.data.tags[0]}</span>
                  </>
                )}
              </div>
              <a href={`/blog/${featured.slug}`}>
                <h2 class="font-brand text-neutral-900 dark:text-white mb-3 leading-tight transition-colors duration-300 group-hover:text-primary dark:group-hover:text-primary-light line-clamp-2 text-3xl">{featured.data.title}</h2>
              </a>
              <p class="text-neutral-600 dark:text-neutral-400 line-clamp-3 mb-5 text-sm leading-relaxed">{featured.data.description}</p>
              <div class="mt-auto pt-4">
                <a href={`/blog/${featured.slug}`} class="inline-flex items-center gap-2 text-sm font-semibold text-primary dark:text-primary-light transition-all duration-300 group/link">
                  <span class="relative">Read More <span class="absolute bottom-0 left-0 w-0 h-0.25 bg-bg-secondary dark:bg-bg-secondary-light transition-all duration-300 group-hover/link:w-full"></span></span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover/link:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>
    )}

    <!-- Blog Grid -->
    <section>
      <div class="site-container space-y-10 md:space-y-16">
        <div class="grid gap-x-6 gap-y-10 md:grid-cols-2 xl:grid-cols-3">
          {posts.map((post) => (
            <article class="group relative overflow-hidden bg-bg-secondary border-primary/35 p-4 dark:bg-neutral-900 rounded-2xl backdrop-blur-sm transition-all duration-500">
              <div class="relative overflow-hidden rounded-2xl border-4 border-white dark:border-neutral-800/60 aspect-[3/2]">
                <img src={post.data.image || "/assets/blog/ai-cover.webp"} alt={post.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
                  <span class="w-14 h-14 bg-white/95 dark:bg-neutral-800/95 backdrop-blur-sm rounded-full flex items-center justify-center transform translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 shadow-lg hover:scale-110">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
                  </span>
                </div>
                <a class="absolute inset-0 z-10" href={`/blog/${post.slug}`}><span class="sr-only">Read More About {post.data.title}</span></a>
              </div>
              <div class="p-6 px-2 md:p-6 flex flex-col">
                <div class="flex items-center text-sm mb-4 gap-2">
                  <time class="inline-flex items-center text-neutral-500 dark:text-neutral-400 text-xs">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5 opacity-60"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                    {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
                  </time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <>
                      <span class="text-neutral-400 dark:text-neutral-500">·</span>
                      <span class="inline-flex items-center rounded-full bg-bg-secondary/8 dark:bg-bg-secondary/15 px-3 py-1 text-[11px] font-light text-primary/75 dark:text-primary-light/85 border border-primary/25 dark:border-primary/25">{post.data.tags[0]}</span>
                    </>
                  )}
                </div>
                <a href={`/blog/${post.slug}`}>
                  <h2 class="font-brand text-neutral-900 dark:text-white mb-3 leading-tight transition-colors duration-300 group-hover:text-primary dark:group-hover:text-primary-light line-clamp-2 text-2xl">{post.data.title}</h2>
                </a>
                <p class="text-neutral-600 dark:text-neutral-400 line-clamp-3 mb-5 text-sm leading-relaxed">{post.data.description}</p>
                <div class="mt-auto pt-4">
                  <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-2 text-sm font-semibold text-primary dark:text-primary-light transition-all duration-300 group/link">
                    <span class="relative">Read More <span class="absolute bottom-0 left-0 w-0 h-0.25 bg-bg-secondary dark:bg-bg-secondary-light transition-all duration-300 group-hover/link:w-full"></span></span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover/link:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Pagination -->
        <nav aria-label="Pagination" class="flex justify-center mt-12">
          <ul class="flex items-center gap-1">
            <li>
              <span class="flex items-center justify-center w-10 h-10 rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-400 dark:text-neutral-600 cursor-not-allowed" aria-disabled="true">
                <span class="sr-only">Previous</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
              </span>
            </li>
            {Array.from({ length: Math.min(5, totalPages) }, (_, i) => i + 1).map((page) => (
              <li>
                <a
                  href={page === 1 ? "/blog" : `/blog/page/${page}`}
                  class={`flex items-center justify-center w-10 h-10 rounded-md border transition-colors ${page === currentPage ? "bg-primary text-white border-primary" : "border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800"}`}
                  aria-label={`Go to page ${page}`}
                  aria-current={page === currentPage ? "page" : undefined}
                >
                  {page}
                </a>
              </li>
            ))}
            {totalPages > 5 && (
              <li><span class="flex items-center justify-center w-10 h-10 text-neutral-500 dark:text-neutral-400">...</span></li>
            )}
            {totalPages > 5 && (
              <li>
                <a href={`/blog/page/${totalPages}`} class="flex items-center justify-center w-10 h-10 rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors" aria-label={`Go to page ${totalPages}`}>{totalPages}</a>
              </li>
            )}
            <li>
              <a href={currentPage < totalPages ? `/blog/page/${currentPage + 1}` : "#"} class={`flex items-center justify-center w-10 h-10 rounded-md border transition-colors ${currentPage < totalPages ? "border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800" : "border-neutral-200 dark:border-neutral-700 text-neutral-400 dark:text-neutral-600 cursor-not-allowed"}`} aria-label="Go to next page">
                <span class="sr-only">Next</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </section>
  </section>

  <Footer lang="en" />

  <script>
    import AOS from "aos";
    import "aos/dist/aos.css";
    AOS.init({ duration: 600, easing: "ease-out", once: true });
  </script>
</Layout>
