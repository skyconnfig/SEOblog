  <!-- Hero video audio toggle -->
  <script>
    (function () {
      function initAudioToggle(card) {
        if (card.dataset.enhanced === "true") return;
        const video = card.querySelector(".hero-video-media");
        const btn = card.querySelector(".hero-video-audio-toggle");
        if (!(video instanceof HTMLVideoElement) || !(btn instanceof HTMLButtonElement)) return;

        function playVideo() { video.play().catch(() => {}); }
        function getLangLabel(muted) {
          var en = document.documentElement.getAttribute('data-lang') === 'en';
          if (muted) return en ? 'Muted' : '静音';
          return en ? 'Sound On' : '声音开';
        }
        function updateLabel() {
          const label = btn.querySelector('[data-role="audio-label"]');
          const isMuted = video.muted;
          var labelText = getLangLabel(isMuted);
          btn.dataset.state = isMuted ? "muted" : "unmuted";
          btn.setAttribute("aria-pressed", String(!isMuted));
          btn.setAttribute("aria-label", labelText);
          if (label) label.textContent = labelText;
        }

        playVideo();
        updateLabel();
        btn.addEventListener("click", () => {
          video.muted = !video.muted;
          if (!video.muted) video.volume = 1;
          playVideo();
          updateLabel();
        });
        video.addEventListener("volumechange", updateLabel);
        card.dataset.enhanced = "true";
      }

      function init() {
        document.querySelectorAll(".hero-video-card").forEach((el) => {
          if (el instanceof HTMLElement) initAudioToggle(el);
        });
      }

      if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init, { once: true });
      else init();
      document.addEventListener("astro:page-load", init);
    })();
  </script>
