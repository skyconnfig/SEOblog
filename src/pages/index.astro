---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import AnimatedText from "../components/AnimatedText.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 3);

const projects = [
  {
    id: "redol-ai",
    title: "Redol AI",
    description: "AI Agent for Social Media Content Production",
    videoSrc: "/assets/works/redol-ai.mp4",
    poster: "/assets/works/redol-ai.webp",
    url: "https://redol.ai",
    tags: ["AI SaaS", "PM", "PLG", "AI Agent", "Indie Project"],
    delay: "0",
  },
  {
    id: "realibox",
    title: "Realibox",
    description: "3D + AI Agent SaaS for intelligent 3D asset production workflow, from mockup design to 3D configurators, animations, and scene rendering",
    videoSrc: "/assets/works/realibox.mp4",
    poster: "/assets/works/realibox.jpg",
    url: "https://realibox.com",
    tags: ["3D SaaS", "AI Agent", "Product Manager", "Global Operations"],
    delay: "100",
  },
  {
    id: "insmind",
    title: "Insmind",
    description: "AI-powered image editing SaaS platform, empowered 0-1 growth stage as PMF and SEM consultant",
    videoSrc: "/assets/works/insmind.mp4",
    poster: "/assets/works/insmind.jpg",
    url: "https://insmind.com",
    tags: ["AI Image", "AI Design", "PMF Consultant", "SEM Consultant"],
    delay: "200",
  },
  {
    id: "melogen-ai",
    title: "Melogen AI",
    description: "AI audio SaaS for musicians and music enthusiasts, developed as an indie project by a musician",
    videoSrc: "/assets/works/melogenai.mp4",
    poster: "/assets/works/melogenai.jpg",
    url: "https://melogenai.com",
    tags: ["AI Audio", "Music SaaS", "Indie Project", "Musician"],
    delay: "300",
  },
  {
    id: "plushthis",
    title: "PlushThis",
    description: "Alt-style plush toy brand e-commerce, empowered 0-1 growth as digital marketing consultant with full SEO and brand strategy",
    videoSrc: "/assets/works/plushthis.mp4",
    poster: "/assets/works/plushthis.jpg",
    url: "https://plushthis.com",
    tags: ["E-commerce", "Digital Marketing", "SEO Strategy", "Brand Consultant"],
    delay: "400",
  },
];

const tools = [
  { src: "/assets/tools/logo/realibox-logo.svg", alt: "Realibox", w: "24px" },
  { src: "/assets/tools/logo/melogen-logo.png", alt: "Melogen", w: "22px" },
  { src: "/assets/tools/logo/plushthis-logo.png", alt: "PlushThis", w: "20px" },
  { src: "/assets/tools/logo/slashpuffies-logo.png", alt: "SlashPuffies", w: "20px" },
  { src: "/assets/tools/logo/redol-logo.webp", alt: "Redol", w: "24px" },
  null,
  null,
  null,
];
---

<Layout title="果叔 - AI 产品经理 &amp; 数字营销专家" description="欢迎来到果叔的个人网站。我是一名 AI 产品经理、独立开发者、数字营销专家，同时也有音乐背景。">
  <Navbar lang="zh-CN" />

  <!-- ==================== HERO ==================== -->
  <div class="relative site-container z-20 w-full mx-auto mt-16 px-4 md:mt-[72px] lg:mt-20 xl:px-0">
    <div class="relative w-full px-4 flex flex-col items-center justify-between md:flex-row mb-16">
      <!-- Left: Text -->
      <div class="relative w-full md:max-w-[420px] md:w-1/2 text-center sm:text-left sm:-mt-8">
        <h1 class="mb-4">
          <div class="lang-zh-block">
            <AnimatedText text="你好，我是果叔" as="div" class="text-5xl text-primary leading-tight md:text-4xl lg:text-6xl font-brand" duration="0.5" delay="0.1" stagger="0.08" />
          </div>
          <div class="lang-en-block">
            <AnimatedText text="Hi, I'm Mr. Guo" as="div" class="text-5xl text-primary leading-tight md:text-4xl lg:text-6xl font-brand" duration="0.5" delay="0.1" stagger="0.08" />
          </div>
        </h1>

        <div class="mb-2 lang-zh-block">
          <AnimatedText text="欢迎来到我的个人网站。我是一名 AI 产品经理、独立开发者、数字营销专家，同时也有音乐背景。" as="div" class="text-base text-neutral-700 dark:text-neutral-300" duration="0.5" delay="0.3" stagger="0.015" />
        </div>
        <div class="mb-2 lang-en-block">
          <AnimatedText text="Welcome to my personal site. I'm an AI Product Manager, indie developer, digital marketing expert, and also a musician." as="div" class="text-base text-neutral-700 dark:text-neutral-300" duration="0.5" delay="0.3" stagger="0.015" />
        </div>
        <div class="mb-4 lang-zh-block">
          <AnimatedText text="我相信世界既可以由音符组成，也可以由数学公式构成，音乐流淌在万物的每一个粒子中。" as="div" class="text-base text-neutral-700 dark:text-neutral-300" duration="0.5" delay="0.5" stagger="0.015" />
        </div>
        <div class="mb-4 lang-en-block">
          <AnimatedText text="I believe the world is made of both musical notes and mathematical formulas — music flows through every particle of existence." as="div" class="text-base text-neutral-700 dark:text-neutral-300" duration="0.5" delay="0.5" stagger="0.015" />
        </div>

        <!-- Follow button -->
        <div data-aos="fade-up-sm" data-aos-delay="900" data-aos-duration="500" data-aos-once="true">
          <a href="https://x.com/gzzhangguo" target="_self" class="flex justify-center items-center flex-grow-0 flex-shrink-0 relative gap-1.5 px-5 py-[12px] rounded-xl bg-btn-primary dark:bg-btn-primary-dark border-[0] border-[rgba(138,127,255,0.2)] shadow-[0px_2px_3px_0_rgba(0,0,0,0.1)] max-w-60 transition duration-400 ease-in-out hover:bg-btn-primary-hover dark:hover:bg-btn-primary-dark-hover hover:translate-y-[-2px] hover:shadow-[0px_6px_9px_0_rgba(61,99,171,0.15)] dark:shadow-[0px_6px_9px_0_rgba(0,0,0,0.2)] m-auto mt-4 text-center sm:text-left sm:m-0 sm:mt-6 max-w-[200px]">
            <span class="lang-zh flex gap-1 items-center justify-center text-sm font-medium text-center text-neutral-50">在 𝕏 上关注我</span>
            <span class="lang-en flex gap-1 items-center justify-center text-sm font-medium text-center text-neutral-50">Follow me on 𝕏</span>
          </a>
        </div>

        <!-- Social Cards -->
        <div class="social mt-8 mb-8" data-aos="fade-up-sm" data-aos-delay="1000" data-aos-duration="600" data-aos-once="true">
          <div class="social-cards-wrapper">
            <div class="social-list">
              <a href="https://github.com/mrzhangguoguo" target="_blank" rel="noopener noreferrer" class="social-item" style="--index: 0; --total: 5;">
                <img src="/assets/social/social-github.jpg" alt="Github" class="social-image" />
                <div class="social-info"><div class="social-username">@mrzhangguoguo</div></div>
              </a>
              <a href="https://www.xiaohongshu.com/user/profile/5e17eb720000000001005546" target="_blank" rel="noopener noreferrer" class="social-item" style="--index: 1; --total: 5;">
                <img src="/assets/social/social-xiaohongshu.jpg" alt="Xiaohongshu" class="social-image" />
                <div class="social-info"><div class="social-username">@zhangguo</div></div>
              </a>
              <a href="https://x.com/gzzhangguo" target="_blank" rel="noopener noreferrer" class="social-item" style="--index: 2; --total: 5;">
                <img src="/assets/social/social-twitter.jpg" alt="Twitter" class="social-image" />
                <div class="social-info"><div class="social-username">@gzzhangguo</div></div>
              </a>
              <button type="button" class="social-item social-wechat-trigger" style="--index: 3; --total: 5;" data-wechat-qr="/assets/social/social-wechat-public.jpg">
                <img src="/assets/social/social-wechat.png" alt="WeChat" class="social-image" />
                <div class="social-info"><div class="social-username">@mrguo</div></div>
              </button>
              <a href="https://b23.tv/PCHQvUS" target="_blank" rel="noopener noreferrer" class="social-item" style="--index: 4; --total: 5;">
                <img src="/assets/social/social-bilibili.svg" alt="Bilibili" class="social-image" />
                <div class="social-info"><div class="social-username">@guoshu</div></div>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Hero Video Card -->
      <div class="relative justify-end w-full mt-16 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0" data-aos="fade-left-sm" data-aos-delay="300" data-aos-duration="800" data-aos-once="true">
        <div class="hero-video-card">
          <div class="hero-video-frame">
            <div class="hero-video-square hero-video-square--tl"></div>
            <div class="hero-video-square hero-video-square--tr"></div>
            <div class="hero-video-square hero-video-square--bl"></div>
            <div class="hero-video-square hero-video-square--br"></div>
            <div class="hero-video-shell">
              <video class="hero-video-media" autoplay muted loop playsinline preload="auto" poster="/assets/home/guoshu-zhenghuo-poster.jpg">
                <source src="/assets/home/guoshu-zhenghuo.mp4" type="video/mp4" />
              </video>
              <button type="button" class="hero-video-audio-toggle" data-muted-label="Muted" data-unmuted-label="Sound On" data-state="muted" aria-pressed="false" aria-label="Muted">
                <span class="hero-video-audio-toggle__icon hero-video-audio-toggle__icon--muted">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"></path><line x1="22" x2="16" y1="9" y2="15"></line><line x1="16" x2="22" y1="9" y2="15"></line></svg>
                </span>
                <span class="hero-video-audio-toggle__icon hero-video-audio-toggle__icon--unmuted">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"></path><path d="M16 9a5 5 0 0 1 0 6"></path><path d="M19.364 18.364a9 9 0 0 0 0-12.728"></path></svg>
                </span>
                <span class="hero-video-audio-toggle__label" data-role="audio-label">
                  <span class="lang-zh">静音</span>
                  <span class="lang-en">Muted</span>
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== EXPLORE SECTION ==================== -->
  <section class="mt-[104px] mb-12" data-aos="fade-up-sm" data-aos-delay="100" data-aos-duration="600" data-aos-once="true">
    <div class="py-8 sm:py-12 md:py-16 md:pb-12 site-container">
      <div class="space-y-6 sm:space-y-8 md:space-y-8">
        <div class="relative z-20 w-full mx-auto mt-12 mb-16 text-center">
          <h2 class="text-4xl font-brand text-center tracking-normal sm:text-5xl text-primary">
            <div class="lang-zh-block">
              <AnimatedText text="探索 ↓" as="div" duration="0.6" delay="0.2" stagger="0.08" />
            </div>
            <div class="lang-en-block">
              <AnimatedText text="Explore ↓" as="div" duration="0.6" delay="0.2" stagger="0.08" />
            </div>
          </h2>
        </div>

        <div class="explore-content w-full relative mt-6 sm:mt-8">
          <div class="explore-list w-full relative grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
            <!-- Column 1 -->
            <div class="explore-column-1 w-full flex gap-3 sm:gap-4 flex-col">
              <!-- PLG Keyboard -->
              <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 h-[200px] sm:h-[220px] md:h-[264px]" data-aos="fade-up-sm" data-aos-delay="500" data-aos-duration="600" data-aos-once="true">
                <div class="p-5 relative z-10">
                  <h3 class="font-brand text-[28px] text-primary"><span class="lang-zh">PLG 增长信徒</span><span class="lang-en">PLG Believer</span></h3>
                  <div class="lang-zh">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">市场机会定义产品，产品体验驱动增长。</p>
                  </div>
                  <div class="lang-en">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">Market opportunity defines product; product experience drives growth.</p>
                  </div>
                </div>
                <div class="absolute keyboard right-[-35%] sm:right-[-50%] md:right-[-58%] bottom-0 top-0 flex items-center self-center w-[300px] sm:w-[320px] md:w-[390px] h-auto">
                  <img src="/assets/tools/keyboard.png" alt="Keyboard" class="w-full h-full object-cover" />
                </div>
              </div>
              <!-- Game Cassettes -->
              <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 h-[180px] sm:h-[200px]" data-aos="fade-up-sm" data-aos-delay="600" data-aos-duration="600" data-aos-once="true">
                <div class="p-5 relative z-10">
                  <h3 class="font-brand text-[28px] text-primary"><span class="lang-zh">我的最爱</span><span class="lang-en">My Favorites</span></h3>
                  <div class="lang-zh">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">精选我真正喜欢的东西。</p>
                  </div>
                  <div class="lang-en">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">A curated collection of things I truly love.</p>
                  </div>
                </div>
                <div class="explore-figure game-container absolute right-0 bottom-0 top-0 w-full h-full">
                  <div class="absolute game right-[-21%] bottom-0 top-0 mt-[-10%] flex items-center self-center w-auto h-[100px] sm:h-[120px] md:h-[130px] z-10"><img src="/assets/tools/game/05-game-cassette.png" class="w-full h-full object-cover" /></div>
                  <div class="absolute game right-[-19%] bottom-0 top-0 mt-[-5%] flex items-center self-center w-auto h-[100px] sm:h-[120px] md:h-[130px] z-20"><img src="/assets/tools/game/04-game-cassette.png" class="w-full h-full object-cover" /></div>
                  <div class="absolute game right-[-16%] bottom-0 top-0 mt-0 flex items-center self-center w-auto h-[100px] sm:h-[120px] md:h-[130px] z-30"><img src="/assets/tools/game/03-game-cassette.png" class="w-full h-full object-cover" /></div>
                  <div class="absolute game right-[-13%] bottom-0 top-0 mt-[5%] flex items-center self-center w-auto h-[100px] sm:h-[120px] md:h-[130px] z-40"><img src="/assets/tools/game/02-game-cassette.png" class="w-full h-full object-cover" /></div>
                  <div class="absolute game right-[-10%] bottom-0 top-0 mt-[10%] flex items-center self-center w-auto h-[100px] sm:h-[120px] md:h-[130px] z-50"><img src="/assets/tools/game/01-game-cassette.png" class="w-full h-full object-cover" /></div>
                </div>
              </div>
            </div>

            <!-- Column 2 -->
            <div class="explore-column-2 w-full flex gap-3 sm:gap-4 flex-col">
              <!-- Retro Computer -->
              <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 h-[180px] sm:h-[200px]" data-aos="fade-up-sm" data-aos-delay="700" data-aos-duration="600" data-aos-once="true">
                <div class="p-5 relative z-10">
                  <h3 class="font-brand text-[28px] text-primary"><span class="lang-zh">写作</span><span class="lang-en">Writing</span></h3>
                  <div class="lang-zh">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">AI 工具、PLG 增长、Vibe Coding 和数字营销。</p>
                  </div>
                  <div class="lang-en">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">AI tools, PLG growth, Vibe Coding, and digital marketing.</p>
                  </div>
                </div>
                <div class="explore-figure computer absolute right-[5%] sm:right-[-10%] md:right-[-7%] bottom-[14%] w-[120px] sm:w-[130px] md:w-[148px] h-auto">
                  <img src="/assets/tools/retro-computer.png" alt="Retro Computer" class="w-full h-full object-cover z-10 relative" />
                  <div class="computer-screen absolute inset-0 w-[92px] sm:w-[100px] md:w-[116px] h-[76px] sm:h-[86px] md:h-[96px] top-[10.5%] left-[10%] rounded-[8px] rounded-b-[3px] overflow-hidden z-20">
                    <video id="explore-computer-video" src="/assets/tools/dreamcore.mp4" poster="/assets/tools/dreamcore.jpg" autoplay loop muted playsinline webkit-playsinline preload="auto" controlslist="nodownload noplaybackrate nofullscreen noremoteplayback" disablepictureinpicture class="w-full h-full object-cover"></video>
                  </div>
                </div>
              </div>
              <!-- Tool Grid -->
              <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 h-[200px] sm:h-[220px] md:h-[264px]" data-aos="fade-up-sm" data-aos-delay="800" data-aos-duration="600" data-aos-once="true">
                <div class="p-5 relative z-10">
                  <h3 class="font-brand text-[28px] text-primary"><span class="lang-zh">我的项目</span><span class="lang-en">My Projects</span></h3>
                  <div class="lang-zh">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">我正在构建和开发的项目，包括跨境电商和 AI SaaS 产品。</p>
                  </div>
                  <div class="lang-en">
                    <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">Projects I'm building, from cross-border e-commerce to AI SaaS products.</p>
                  </div>
                </div>
                <div class="explore-figure absolute machine right-[5%] sm:right-[-10%] md:right-[-7%] bottom-0 top-0 flex items-center">
                  <div class="relative w-[198px] h-[180px] overflow-hidden rounded-3xl bg-[url('/assets/tools/deck.png')] bg-cover flex items-start justify-center">
                    <div class="tools-container relative m-auto mt-[28px]">
                      <div class="tools-list grid grid-cols-4 gap-[12px]">
                        {tools.map((tool) => (
                          <div class="relative tool-item w-[32px] h-[32px] flex items-center justify-center bg-[url('/assets/tools/tool-icon-bg.png')] bg-cover">
                            {tool && <img src={tool.src} alt={tool.alt} style={{ width: tool.w }} class="h-auto" />}
                          </div>
                        ))}
                      </div>
                    </div>
                    <div class="bar absolute bottom-[24px] left-[18px] right-[18px] bg-[url('/assets/tools/spin-bar.svg')] bg-cover w-[calc(100%-36px)] h-[39px] flex items-center justify-center overflow-hidden rounded-[10px]">
                      <div class="absolute bar-spin-inner w-auto h-full flex items-center justify-center gap-2">
                        <img src="/assets/tools/spin.png" alt="" class="spin object-cover w-auto h-[72%]" />
                        <img src="/assets/tools/spin.png" alt="" class="spin object-cover w-auto h-[72%]" />
                        <img src="/assets/tools/spin.png" alt="" class="spin object-cover w-auto h-[72%]" />
                        <img src="/assets/tools/spin.png" alt="" class="spin object-cover w-auto h-[72%]" />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Column 3: Matter.js -->
            <div class="explore-column-3 w-full col-span-1 sm:col-span-2 lg:col-span-1">
              <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50" data-aos="fade-up-sm" data-aos-delay="900" data-aos-duration="600" data-aos-once="true">
                <div class="explore-figure tool-stack-box relative rounded-xl overflow-hidden w-full h-[480px] sm:h-[400px] md:h-[480px]">
                  <div class="matter-wrapper">
                    <div id="matter" class="tricks-spacer">
                      <div class="tricks-view" id="tricks-view"></div>
                    </div>
                    <div class="tricks-matter">
                      <div class="tricks-canvas"></div>
                      <div class="tricks-elements"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PROJECTS ==================== -->
  <section class="mt-[104px] mb-12" data-aos="fade-up-sm" data-aos-delay="100" data-aos-duration="600" data-aos-once="true">
    <div class="py-16 md:py-16 md:pb-12">
      <div class="site-container space-y-8 md:space-y-8">
        <div class="relative z-20 w-full mx-auto mt-12 mb-16 text-center">
          <h2 class="text-4xl font-brand text-center tracking-normal sm:text-5xl text-primary">
            <div class="lang-zh-block">
              <AnimatedText text="精选项目 ↓" as="div" duration="0.6" delay="0.2" stagger="0.08" />
            </div>
            <div class="lang-en-block">
              <AnimatedText text="Featured Projects ↓" as="div" duration="0.6" delay="0.2" stagger="0.08" />
            </div>
          </h2>
          <div class="lang-zh-block mt-3 text-sm leading-6 sm:mt-4 lg:mt-6 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg text-neutral-700 dark:text-neutral-300 max-w-full lg:max-w-3xl m-auto">
            <AnimatedText text="在这些项目中，我扮演了多种角色：产品经理、开发者、数字营销顾问、PMF 顾问和商业战略顾问。" as="div" duration="0.6" delay="0.6" stagger="0.03" />
          </div>
          <div class="lang-en-block mt-3 text-sm leading-6 sm:mt-4 lg:mt-6 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg text-neutral-700 dark:text-neutral-300 max-w-full lg:max-w-3xl m-auto">
            <AnimatedText text="In these projects I've worn many hats: Product Manager, Developer, Digital Marketing Consultant, PMF Consultant, and Business Strategy Advisor." as="div" duration="0.6" delay="0.6" stagger="0.03" />
          </div>
        </div>

