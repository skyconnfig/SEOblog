---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import AnimatedText from "../../components/AnimatedText.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import Footer from "../../components/Footer.astro";
import fs from "node:fs";
import path from "node:path";

const projects = [
  {
    id: "redol-ai",
    title: "Redol AI",
    description: "AI Agent for Social Media Content Production",
    videoSrc: "/assets/works/redol-ai.mp4",
    poster: "/assets/works/redol-ai.webp",
    url: "https://redol.ai",
    tags: ["AI SaaS", "PM", "PLG", "AI Agent", "Indie Project"],
    delay: "0",
  },
  {
    id: "realibox",
    title: "Realibox",
    description: "3D + AI Agent SaaS for intelligent 3D asset production workflow, from mockup design to 3D configurators, animations, and scene rendering",
    videoSrc: "/assets/works/realibox.mp4",
    poster: "/assets/works/realibox.jpg",
    url: "https://realibox.com",
    tags: ["3D SaaS", "AI Agent", "Product Manager", "Global Operations"],
    delay: "100",
  },
  {
    id: "insmind",
    title: "Insmind",
    description: "AI-powered image editing SaaS platform, empowered 0-1 growth stage as PMF and SEM consultant",
    videoSrc: "/assets/works/insmind.mp4",
    poster: "/assets/works/insmind.jpg",
    url: "https://insmind.com",
    tags: ["AI Image", "AI Design", "PMF Consultant", "SEM Consultant"],
    delay: "200",
  },
  {
    id: "melogen-ai",
    title: "Melogen AI",
    description: "AI audio SaaS for musicians and music enthusiasts, developed as an indie project by a musician",
    videoSrc: "/assets/works/melogenai.mp4",
    poster: "/assets/works/melogenai.jpg",
    url: "https://melogenai.com",
    tags: ["AI Audio", "Music SaaS", "Indie Project", "Musician"],
    delay: "300",
  },
  {
    id: "plushthis",
    title: "PlushThis",
    description: "Alt-style plush toy brand e-commerce, empowered 0-1 growth as digital marketing consultant with full SEO and brand strategy",
    videoSrc: "/assets/works/plushthis.mp4",
    poster: "/assets/works/plushthis.jpg",
    url: "https://plushthis.com",
    tags: ["E-commerce", "Digital Marketing", "SEO Strategy", "Brand Consultant"],
    delay: "400",
  },
];
// Filter out hidden/unpublished built-in projects, merge works.json overrides
const hiddenSlugs = (() => { try { return JSON.parse(fs.readFileSync(path.resolve("src/data/works-hidden.json"), "utf-8")); } catch { return []; } })();
const hiddenSet = new Set(hiddenSlugs);
const allWorks = (() => { try { return JSON.parse(fs.readFileSync(path.resolve("src/data/works.json"), "utf-8")); } catch { return []; } })();
const worksBySlug = Object.fromEntries(allWorks.filter((w) => w.published !== false).map((w) => [w.slug, w]));
const unpublishedSlugs = new Set(allWorks.filter((w) => w.published === false).map((w) => w.slug));
const visibleProjects = projects
  .filter((p) => !hiddenSet.has(p.id) && !unpublishedSlugs.has(p.id))
  .map((p) => {
    const override = worksBySlug[p.id];
    return override ? { ...p, title: override.title, description: override.description, tags: override.tags, url: override.siteUrl } : p;
  });

// Read admin-published works (exclude slugs already in hardcoded projects)
const builtInSlugs = new Set(projects.map((p) => p.id));
let adminWorks = allWorks.filter((w) => w.published !== false && !builtInSlugs.has(w.slug));
---

<Layout title="My Projects - LXSBest" description="I've played multiple roles in these projects, from product manager and developer to digital marketing consultant, PMF advisor, and business strategy consultant." lang="en">
  <Navbar lang="en" />

  <section class="relative z-20 container mx-auto my-12 px-7 lg:px-0">
    <div class="relative z-20 w-full mx-auto mt-16 mb-16 text-center">
      <h2 class="text-4xl font-brand text-center tracking-normal text-primary sm:text-4xl lg:text-5xl">
        <AnimatedText text="My Projects" as="div" duration="0.6" delay="0.2" stagger="0.08" />
      </h2>
      <div class="mt-3 text-sm leading-6 sm:mt-4 lg:mt-6 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg text-neutral-700 dark:text-neutral-300 max-w-full lg:max-w-2xl m-auto">
        <AnimatedText text="I've played multiple roles in these projects, from product manager and developer to digital marketing consultant, PMF advisor, and business strategy consultant." as="div" duration="1" delay="0.6" stagger="0.03" />
      </div>
    </div>

    <section class="py-8 md:py-8">
      <div class="space-y-8 md:space-y-10">
        {visibleProjects.map((project) => (
          <ProjectCard
            id={project.id}
            title={project.title}
            description={project.description}
            videoSrc={project.videoSrc}
            poster={project.poster}
            url={project.url}
            tags={project.tags}
            delay={project.delay}
          />
        ))}
        {adminWorks.map((w, i) => (
          <article
            class="group relative overflow-hidden transition-all duration-500 mb-8 bg-white/85 p-5 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm"
            data-aos="fade-up"
            data-aos-duration="500"
            data-aos-delay={600 + i * 100}
            data-aos-once="true"
          >
            <div class="relative overflow-hidden aspect-video rounded-xl">
              <img src={w.cover || "/assets/blog/ai-cover.webp"} alt={w.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
                <div class="flex items-center justify-center w-14 h-14 rounded-full bg-white/95 backdrop-blur-sm shadow-lg transform translate-y-8 group-hover:translate-y-0 transition-all duration-500 group-hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
                </div>
              </div>
            </div>
            <div class="px-1 pt-6 pb-2 md:px-1 md:pt-6 md:pb-2">
              <div class="flex items-start justify-between gap-3 mb-3">
                <h3 class="text-neutral-900 dark:text-white leading-tight font-brand transition-colors duration-300 group-hover:text-primary dark:group-hover:text-primary-light text-2xl md:text-3xl">{w.title}</h3>
                <div class="flex-shrink-0 mt-1">
                  <div class="flex items-center justify-center w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-light transition-all duration-300 group-hover:bg-primary dark:group-hover:bg-primary-light group-hover:text-white dark:group-hover:text-neutral-900 group-hover:rotate-45">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
                  </div>
                </div>
              </div>
              <div class="flex flex-wrap gap-1.5 mb-3">
                {(w.tags || []).map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-primary/8 dark:bg-primary/15 px-2.5 py-0.5 text-[10px] font-medium text-primary-dark dark:text-primary-light border border-primary/10 dark:border-primary/20">{tag}</span>
                ))}
              </div>
              <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed text-base md:text-lg line-clamp-2">{w.description}</p>
            </div>
            <a href={w.siteUrl} target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10"><span class="sr-only">View {w.title}</span></a>
          </article>
        ))}
      </div>
    </section>
  </section>

  <Footer lang="en" />

  <script>
    import AOS from "aos";
    import "aos/dist/aos.css";
    AOS.init({ duration: 600, easing: "ease-out", once: true });
  </script>
</Layout>
