    fileType: "PDF",
    fileSize: "5.9MB",
    url: "/resources/en-identifying-scaling-ai-use-cases",
  },
  {
    category: "ai-dev",
    cover: "/assets/resource-previews/a-practical-guide-to-building-agents/page-1.jpg",
    typeTag: { label: "AI & Dev", color: "purple" },
