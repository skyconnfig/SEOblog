---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import AnimatedText from "../../components/AnimatedText.astro";
import DownloadModal from "../../components/DownloadModal.astro";
import Footer from "../../components/Footer.astro";
import { resources, getResourceBySlug, colorMap } from "../../data/resources";

export function getStaticPaths() {
  return resources.map((r) => ({
    params: { slug: r.slug },
    props: { resource: r },
  }));
}

const { resource } = Astro.props;
const isFree = resource.priceTag.label === "Free";
---

<Layout title={`${resource.title} - LXSBest`} description={resource.description}>
  <Navbar lang="en" />

  <section class="relative z-20 container mx-auto my-12 px-7 lg:px-0">
    <!-- Back link -->
    <div class="max-w-4xl mx-auto mb-8" data-aos="fade-up">
      <a href="/resources" class="inline-flex items-center gap-1 text-sm text-neutral-500 hover:text-primary dark:text-neutral-400 dark:hover:text-primary-light transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Back to Resources
      </a>
    </div>

    <!-- Detail Card -->
    <div class="max-w-4xl mx-auto bg-white/85 dark:bg-bg-secondary-dark border-[.75px] border-solid border-primary/15 rounded-2xl backdrop-blur-sm overflow-hidden" data-aos="fade-up">
      <!-- Cover -->
      <div class="aspect-[21/9] md:aspect-[3/1] overflow-hidden bg-neutral-100 dark:bg-neutral-800">
        <img src={resource.cover} alt={resource.title} class="w-full h-full object-cover" />
      </div>

      <div class="p-6 md:p-10">
        <!-- Tags -->
        <div class="flex items-center gap-2 mb-4">
          <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${colorMap[resource.typeTag.color]}`}>
            {resource.typeTag.label}
          </span>
          <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${colorMap[resource.priceTag.color]}`}>
            {resource.priceTag.label}
          </span>
        </div>

        <!-- Title -->
        <h1 class="text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-4">
          {resource.title}
        </h1>

        <!-- Description -->
        <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed mb-6 text-base">
          {resource.description}
        </p>

        <!-- File Info -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400 mb-8">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            {resource.fileType}
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            {resource.fileSize}
          </span>
        </div>

        <!-- Divider -->
        <div class="border-t border-dashed border-neutral-200 dark:border-neutral-700 mb-6"></div>

        <!-- Download Section -->
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <p class="text-sm font-medium text-neutral-900 dark:text-neutral-100">Ready to download?</p>
            <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5">
              {isFree ? "This resource is free to download." : "Support with a tip to unlock the download."}
            </p>
          </div>
          {isFree ? (
            <a href={resource.downloadPath} download class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-btn-primary dark:bg-btn-primary-dark text-white text-sm font-medium shadow-[0px_2px_3px_0_rgba(0,0,0,0.1)] transition-all duration-300 hover:bg-btn-primary-hover dark:hover:bg-btn-primary-dark-hover hover:-translate-y-0.5 hover:shadow-[0px_6px_9px_0_rgba(61,99,171,0.15)]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download Free
            </a>
          ) : (
            <button id="download-trigger-btn" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-btn-primary dark:bg-btn-primary-dark text-white text-sm font-medium shadow-[0px_2px_3px_0_rgba(0,0,0,0.1)] transition-all duration-300 hover:bg-btn-primary-hover dark:hover:bg-btn-primary-dark-hover hover:-translate-y-0.5 hover:shadow-[0px_6px_9px_0_rgba(61,99,171,0.15)] cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download
            </button>
          )}
        </div>
      </div>
    </div>
  </section>

  <DownloadModal
    title={resource.title}
    fileType={resource.fileType}
    fileSize={resource.fileSize}
    downloadPath={resource.downloadPath}
    priceLabel={resource.priceTag.label}
  />

  <Footer lang="en" />

  <script>
    import AOS from "aos";
    import "aos/dist/aos.css";
    AOS.init({ duration: 600, easing: "ease-out", once: true });
  </script>

  <script>
    (function () {
      var triggerBtn = document.getElementById("download-trigger-btn");
      if (triggerBtn) {
        triggerBtn.addEventListener("click", function () {
          if (typeof window.openDownloadModal === "function") {
            window.openDownloadModal();
          }
        });
      }
    })();
  </script>
</Layout>
