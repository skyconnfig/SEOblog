---
import AnimatedText from "./AnimatedText.astro";

const socialLinks = [
  { name: "Twitter", href: "#", icon: "M23.643 4.937c-.835.37-1.732.62-2.675.733a4.67 4.67 0 002.048-2.578 9.3 9.3 0 01-2.958 1.13 4.66 4.66 0 00-7.938 4.25 13.23 13.23 0 01-9.602-4.868c-.4.69-.63 1.49-.63 2.342a4.66 4.66 0 002.073 3.878 4.64 4.64 0 01-2.11-.583v.06a4.66 4.66 0 003.74 4.568 4.68 4.68 0 01-2.104.08 4.66 4.66 0 004.352 3.234A9.35 9.35 0 010 19.538a13.2 13.2 0 007.162 2.1c8.594 0 13.29-7.118 13.29-13.29 0-.2-.005-.402-.014-.602a9.5 9.5 0 002.326-2.414l.002-.002z" },
  { name: "GitHub", href: "#", icon: "M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" },
  { name: "Email", href: "#", icon: "M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" },
];
---

<section class="relative min-h-screen flex items-center pt-24 pb-16 px-6 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-gradient-to-br from-indigo-100/40 to-purple-100/40 dark:from-indigo-500/5 dark:to-purple-500/5 rounded-full blur-3xl" />
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-gradient-to-br from-amber-100/40 to-orange-100/40 dark:from-amber-500/5 dark:to-orange-500/5 rounded-full blur-3xl" />
  </div>

  <div class="mx-auto max-w-6xl w-full grid md:grid-cols-2 gap-12 md:gap-16 items-center relative z-10">
    <!-- Left: Text Content -->
    <div class="space-y-8">
      <!-- Greeting -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-neutral-100 dark:bg-neutral-800 text-sm text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
        你好，我是
      </div>

      <!-- Name -->
      <AnimatedText
        text="果叔"
        as="h1"
        class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight"
      />

      <!-- Tagline -->
      <p class="text-lg sm:text-xl text-neutral-500 dark:text-neutral-400 leading-relaxed max-w-md" data-aos="fade-up" data-aos-delay="400">
        PLG 增长信徒 · 独立开发者 · AI 产品经理
      </p>

      <!-- Description -->
      <p class="text-base text-neutral-400 dark:text-neutral-500 leading-relaxed max-w-sm" data-aos="fade-up" data-aos-delay="500">
        专注于 PLG 增长策略、AI 产品设计和开发者体验。写关于增长、产品和技术的思考。
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4" data-aos="fade-up" data-aos-delay="600">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-neutral-900 dark:bg-neutral-100 text-white dark:text-neutral-900 text-sm font-medium hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-all duration-200"
        >
          查看项目
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#blog"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-neutral-200 dark:border-neutral-700 text-sm font-medium hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-all duration-200"
        >
          阅读博客
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex items-center gap-4" data-aos="fade-up" data-aos-delay="700">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="p-2 rounded-xl text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all duration-200"
            aria-label={link.name}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d={link.icon} />
            </svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Right: Video Card -->
    <div class="relative" data-aos="fade-left" data-aos-delay="300">
      <div class="relative group cursor-pointer">
        <!-- Decorative elements -->
        <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 dark:from-indigo-500/5 dark:to-purple-500/5 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

        <!-- Video card -->
        <div class="relative overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-neutral-100 dark:bg-neutral-900 shadow-sm aspect-[4/3]">
          <!-- Placeholder video showing a gradient animation -->
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-indigo-950/30 dark:to-purple-950/30 flex items-center justify-center">
            <div class="text-center space-y-4">
              <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center">
                <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
              <p class="text-sm text-neutral-400">演示视频</p>
            </div>
          </div>
        </div>

        <!-- Label -->
        <div class="absolute -bottom-2 -right-2 px-4 py-2 rounded-xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 shadow-sm text-xs text-neutral-500">
          ✦ 产品演示
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" data-aos="fade" data-aos-delay="1000">
    <div class="w-6 h-10 rounded-full border-2 border-neutral-300 dark:border-neutral-700 flex justify-center">
      <div class="w-1.5 h-3 rounded-full bg-neutral-400 dark:bg-neutral-500 mt-2 animate-bounce" />
    </div>
  </div>
</section>
