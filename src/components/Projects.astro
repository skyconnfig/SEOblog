---
// Projects showcase section with video cards
interface Project {
  title: string;
  description: string;
  tags: string[];
  gradient: string;
}

const projects: Project[] = [
  {
    title: "AI Chat Platform",
    description: "基于 LLM 的智能对话平台，支持多模型切换、上下文管理和团队协作。",
    tags: ["Next.js", "AI SDK", "PostgreSQL"],
    gradient: "from-indigo-500 to-purple-500",
  },
  {
    title: "Growth Analytics",
    description: "PLG 增长分析工具，追踪产品激活、留存和推荐指标。",
    tags: ["React", "Python", "ClickHouse"],
    gradient: "from-emerald-500 to-teal-500",
  },
  {
    title: "DocMind",
    description: "AI 驱动的文档助手，自动生成技术文档和 API 参考。",
    tags: ["Astro", "AI SDK", "MDX"],
    gradient: "from-orange-500 to-rose-500",
  },
];
---

<section id="projects" class="relative px-6 py-24 md:py-32 bg-neutral-50/50 dark:bg-neutral-900/30">
  <div class="mx-auto max-w-6xl">
    <!-- Section Header -->
    <div class="mb-16" data-aos="fade-up">
      <span class="text-xs font-medium uppercase tracking-widest text-neutral-400">Projects</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight">项目</h2>
      <p class="mt-3 text-neutral-500 dark:text-neutral-400 max-w-md">
        最近的一些作品和 Side Projects
      </p>
    </div>

    <!-- Project Cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <article
          class="group relative overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-950 hover:shadow-sm transition-all duration-300"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <!-- Video/Card preview -->
          <a href="#" class="block">
            <div class="aspect-[16/10] overflow-hidden">
              <div class="w-full h-full bg-gradient-to-br {project.gradient} opacity-20 dark:opacity-10 group-hover:scale-105 transition-transform duration-500" />
              <!-- Gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-white/80 via-transparent to-transparent dark:from-neutral-950/80" />
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="text-lg font-semibold tracking-tight group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors">
                {project.title}
              </h3>
              <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed line-clamp-2">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="mt-4 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-xs rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
